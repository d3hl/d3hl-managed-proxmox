{
  "project": "Homelab Proxmox SDN Design",
  "devices": {
    "fortigate_100f": {
      "role": "main firewall and VLAN gateway",
      "management_ip": "10.99.99.2/24",
      "gateway_convention": ".2 on firewall-routed VLANs; VLAN 20 is not routed to the firewall"
    },
    "cisco_c9300": {
      "role": "core L3 switch",
      "management_ip": "10.10.10.1/24",
      "management_vlan": 10,
      "default_gateway": "10.10.10.2"
    },
    "proxmox": {
      "nodes": [
        "nodeA",
        "nodeB",
        "nodeD",
        "nodeF"
      ],
      "base_bridge": "vmbr0",
      "sdn_zone": "ztrunk"
    }
  },
  "vlans": [
    {
      "purpose": "Proxmox management",
      "name": "PROXMOX_MGMT",
      "vlan": 10,
      "subnet": "10.10.10.0/24",
      "gateway": "10.10.10.2",
      "gateway_device": "fortigate",
      "fortigate_interface": "hlvl",
      "vnet": "vmgmt"
    },
    {
      "purpose": "Storage / Ceph",
      "name": "STORAGE_CEPH",
      "vlan": 20,
      "subnet": "10.20.20.0/24",
      "gateway": null,
      "gateway_device": "c9300",
      "fortigate_interface": null,
      "note": "Storage VLAN remains on C9300/storage side and is not routed to the FortiGate.",
      "vnet": "vstore"
    },
    {
      "purpose": "VM services",
      "name": "VM_SERVICES",
      "vlan": 30,
      "subnet": "10.10.30.0/24",
      "gateway": "10.10.30.2",
      "gateway_device": "fortigate",
      "fortigate_interface": "VLAN30_VM_SERVICES",
      "vnet": "vsvc"
    },
    {
      "purpose": "Containers / apps",
      "name": "CONTAINERS_APPS",
      "vlan": 40,
      "subnet": "10.10.40.0/24",
      "gateway": "10.10.40.2",
      "gateway_device": "fortigate",
      "fortigate_interface": "VLAN40_CONTAINERS_APPS",
      "vnet": "vapps"
    },
    {
      "purpose": "Lab / test",
      "name": "LAB_TEST",
      "vlan": 50,
      "subnet": "10.10.50.0/24",
      "gateway": "10.10.50.2",
      "gateway_device": "fortigate",
      "fortigate_interface": "VLAN50_LAB_TEST",
      "vnet": "vlab"
    },
    {
      "purpose": "DMZ / public-facing",
      "name": "DMZ",
      "vlan": 60,
      "subnet": "10.10.60.0/24",
      "gateway": "10.10.60.2",
      "gateway_device": "fortigate",
      "fortigate_interface": "VLAN60_DMZ",
      "vnet": "vdmz"
    },
    {
      "purpose": "Infrastructure management",
      "name": "INFRA_MGMT",
      "vlan": 99,
      "subnet": "10.99.99.0/24",
      "gateway": "10.99.99.2",
      "gateway_device": "fortigate_mgt_hard_switch",
      "fortigate_interface": "mgt",
      "vnet": null
    }
  ],
  "trunks": {
    "c9300_to_fortigate": {
      "interface": "TwentyFiveGigE2/1/2",
      "description": "Trunk_to_FortiGate_100F",
      "allowed_vlans": [
        10,
        11,
        30,
        40,
        50,
        60,
        100
      ]
    },
    "c9300_to_proxmox": {
      "interfaces": [
        {
          "interface": "TenGigabitEthernet2/0/39",
          "description": "Trunk_to_Proxmox_nodeA"
        },
        {
          "interface": "TenGigabitEthernet2/0/41",
          "description": "Trunk_to_Proxmox_nodeB"
        },
        {
          "interface": "TenGigabitEthernet2/0/46",
          "description": "Trunk_to_Proxmox_nodeD"
        }
      ],
      "allowed_vlans": [
        3,
        10,
        11,
        30,
        40,
        50,
        60
      ]
    },
    "proxmox_ovs_trunks": {
      "nodeA": {"port": "en10basep2", "vlans": "3,10,11,30,40,50,60", "bridge": "vmbr0"},
      "nodeB": {"port": "ennic1s1", "vlans": "3,10,11,30,40,50,60", "bridge": "vmbr0"},
      "nodeD": {"port": "eno1", "vlans": "3,10,11,30,40,50,60", "bridge": "vmbr0"},
      "nodeF": {"port": "sfp1", "vlans": "10,11,30,40,50,60", "bridge": "vmbr0", "note": "VLAN 3 via dedicated vmbr3/nic4"}
    }
  }
}
