# Copy to terraform.tfvars and adjust. terraform.tfvars is gitignored — never commit real values.
#
# The API token is NOT set here. Inject it at runtime from 1Password so no secret touches disk:
#
#   export TF_VAR_proxmox_api_token="$(op read 'op://d3HLPRV/Proxmox API for AI/username')=$(op read 'op://d3HLPRV/Proxmox API for AI/credential')"
#   op run -- terraform -chdir=terraform/proxmox-vm plan
#
# Secret references (op://) are documented here as references only and are never resolved in-repo.

# --- Required ---
template_vm_id = 0 # set to the id of an existing PVE template to clone (see PVE-TEMPLATE-001)

# --- Connection (defaults shown) ---
# proxmox_endpoint = "https://10.10.10.10:8006"
# proxmox_insecure = true
# target_node      = "nodeA"

# --- VM shape ---
# vm_id        = 9001
# vm_name      = "tf-demo-vsvc"
# vm_cores     = 2
# vm_memory_mb = 2048

# --- Network (VM_SERVICES / VLAN 30 on the VLAN-aware vmbr0) ---
# network_bridge = "vmbr0"
# vlan_id        = 30
# Static IP example (omit / set "dhcp" to use DHCP):
# ip_address = "10.10.30.50/24"
# ip_gateway = "10.10.30.2"

# --- Cloud-init ---
# ci_username        = "ubuntu"
# ci_ssh_public_keys = ["ssh-ed25519 AAAA... you@host"]
